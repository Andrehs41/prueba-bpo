# Server
PORT=4000

# MySQL (matches docker-compose.yml; host port 3307 -> container 3306)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=bpo_user
DB_PASSWORD=bpo_pass
DB_NAME=multitenant

# Auth
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=8h

# CORS (frontend origin)
CORS_ORIGIN=http://localhost:5173
